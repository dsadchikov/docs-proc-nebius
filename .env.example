# docs-proc-nebius — environment variables
# Copy to .env and fill in real values before running locally.

# ── Endpoint authentication ──────────────────────────────────
AUTH_TOKEN=your-auth-token

# ── vLLM backend ─────────────────────────────────────────────
VLLM_BASE_URL=http://127.0.0.1:8000
VLLM_MODEL_NAME=Qwen2.5-VL-7B-Instruct
GPU_ENABLED=1
MOCK_VLLM=0

# ── Nebius Object Storage ─────────────────────────────────────
S3_ENDPOINT=https://storage.eu-north1.nebius.cloud
S3_BUCKET=your-nos-bucket
S3_ACCESS_KEY=your-access-key-id
S3_SECRET_KEY=your-secret-access-key
S3_REGION=eu-north1

# ── Tune-ables ────────────────────────────────────────────────
PDF_DPI=200
PDF_MAX_PAGES=50
VLLM_TIMEOUT=120
FETCH_TIMEOUT=30

# ── Well-Architected hardening ───────────────────────────────
# Per-request deadline (Req 1.6: /recognize over budget → HTTP 504)
REQUEST_TIMEOUT=30
# Packet (multi-page PDF) deadline — runs one extraction per logical document
PACKET_TIMEOUT=180
# Max inbound request body in bytes (base64 memory-DoS guard); default 25 MiB
MAX_UPLOAD_BYTES=26214400
# CORS origins (comma-separated). Empty = no cross-origin; same-origin /demo still works.
# Pin to your demo origin in production, e.g. https://your-endpoint.nebius.cloud
CORS_ALLOW_ORIGINS=
# SSRF allowlist of hosts for document.type=presigned_url (comma-separated).
# Empty → derived from the S3_ENDPOINT host.
FETCH_URL_ALLOWLIST=
# Expose /metrics (Prometheus text exposition) for Nebius Managed Prometheus
METRICS_ENABLED=1

# ── Batch / Eval Job ─────────────────────────────────────────
JOB_MODE=batch
GPU_HOURLY_USD=2.08
